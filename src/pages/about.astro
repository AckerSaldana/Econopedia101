---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Separator from '../components/ui/Separator.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { SITE } from '../lib/constants';
import { getEntry } from 'astro:content';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About' },
];

const tasmin = await getEntry('authors', 'tasmin-angelina-houssein');
---

<BaseLayout title="About Econopedia 101" description="Learn about Econopedia 101, our mission to make economics and finance accessible, and the team behind the platform.">
  <Container>
    <div class="py-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- Hero Section -->
    <section class="pt-5 lg:pt-6 pb-10 lg:pb-14">
      <div class="border-t-2 border-text-primary pt-3 mb-6">
        <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">About</p>
      </div>
      <h1 class="font-serif text-5xl lg:text-7xl font-semibold text-text-primary leading-[1.1] mb-6 max-w-4xl">
        {SITE.tagline}
      </h1>
      <p class="text-xl lg:text-2xl text-text-secondary leading-relaxed max-w-2xl">
        Your learning platform, news hub, and revision companion — built to make economics and finance genuinely accessible.
      </p>
    </section>

    <Separator />

    <!-- Founder Section -->
    {tasmin && (
      <section class="py-8 lg:py-12">
        <div class="grid lg:grid-cols-[280px_1px_1fr] gap-y-6 lg:gap-y-0 items-start">
          <!-- Avatar Column -->
          <div class="lg:pr-8">
            <div class="w-48 h-48 lg:w-[280px] lg:h-[280px] overflow-hidden bg-surface-elevated border border-border">
              <Image
                src={tasmin.data.avatar}
                alt={tasmin.data.name}
                width={560}
                height={560}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            {tasmin.data.socials && (
              <div class="flex gap-4 mt-4">
                {tasmin.data.socials.twitter && (
                  <a href={tasmin.data.socials.twitter} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Twitter">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  </a>
                )}
                {tasmin.data.socials.linkedin && (
                  <a href={tasmin.data.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="LinkedIn">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                  </a>
                )}
                {tasmin.data.socials.instagram && (
                  <a href={tasmin.data.socials.instagram} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Instagram">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 0 1 1.772 1.153 4.902 4.902 0 0 1 1.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 0 1-1.153 1.772 4.902 4.902 0 0 1-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 0 1-1.772-1.153 4.902 4.902 0 0 1-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 0 1 1.153-1.772A4.902 4.902 0 0 1 5.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 0 0-.748-1.15 3.098 3.098 0 0 0-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 1 1 0 10.27 5.135 5.135 0 0 1 0-10.27zm0 1.802a3.333 3.333 0 1 0 0 6.666 3.333 3.333 0 0 0 0-6.666zm5.338-3.205a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4z" />
                    </svg>
                  </a>
                )}
              </div>
            )}
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-accent mt-3">{tasmin.data.role}</p>
          </div>

          <!-- Vertical rule -->
          <div class="hidden lg:block bg-border" aria-hidden="true"></div>

          <!-- Bio Column -->
          <div class="border-t lg:border-t-0 border-border pt-6 lg:pt-0 lg:pl-8">
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-muted mb-4">Meet the Founder</p>
            <h2 class="font-serif text-3xl lg:text-4xl font-semibold text-text-primary leading-tight mb-6">
              Hi, I'm {tasmin.data.name}.
            </h2>
            <div class="text-text-secondary text-base lg:text-lg leading-relaxed space-y-5 max-w-xl">
              <p>
                If you've ever opened an economics and business news or textbook and felt like you were decoding a foreign language, I want you to know you're not alone.
              </p>
              <p>
                I started this platform because I believe that understanding the economy shouldn't be a privilege reserved for people in boardrooms.
              </p>
              <p>
                Econopedia101 was built specifically for students navigating the Edexcel syllabus, young professionals launching their careers and curious minds who simply want to understand the forces moving today's markets.
              </p>
            </div>
          </div>
        </div>
      </section>
    )}

    <Separator />

    <!-- From Bloomberg Lab to Your Screen -->
    <section class="py-8 lg:py-12">
      <SectionHeading title="From Bloomberg Lab to Your Screen" />
      <div class="grid lg:grid-cols-[1fr_1px_1fr] gap-y-6 lg:gap-y-0 mt-2">
        <!-- Pull quote -->
        <div class="lg:pr-8 flex items-start">
          <blockquote class="border-l-2 border-accent pl-5">
            <p class="font-serif text-2xl lg:text-3xl text-text-primary leading-snug italic">
              "Behind every complex chart is a human story about choices, risks and opportunities."
            </p>
          </blockquote>
        </div>

        <!-- Vertical rule -->
        <div class="hidden lg:block bg-border" aria-hidden="true"></div>

        <!-- Body text -->
        <div class="border-t lg:border-t-0 border-border pt-6 lg:pt-0 lg:pl-8 text-text-secondary text-base leading-relaxed space-y-4">
          <p class="text-text-primary font-medium">
            Our approach combines academic rigour with real-world data.
          </p>
          <p>
            During my time at the University of Hull, I had the opportunity to work in the university's Bloomberg Financial Markets Laboratory. Getting hands on with Bloomberg Terminals — the industry-standard tool for the world's top financial analysts — completely changed how I view data.
          </p>
          <p>
            That's the perspective I bring to every article here: taking "high-level" financial noise and turning it into clear, actionable insights.
          </p>
        </div>
      </div>
    </section>

    <Separator />

    <!-- Our Content & Editorial Standards -->
    <section class="py-8 lg:py-12">
      <SectionHeading title="Our Content & Editorial Standards" />
      <p class="text-text-secondary text-base leading-relaxed max-w-3xl mt-2 mb-8">
        Econopedia101 remains committed to accuracy and transparency. We follow a strict Human-in-the-Loop editorial process.
      </p>
      <div class="grid sm:grid-cols-3">
        <!-- Pillar 1 -->
        <div class="py-4 sm:py-0 sm:pr-6 sm:border-r sm:border-border">
          <p class="text-xs font-bold uppercase tracking-[0.12em] text-accent mb-2">01</p>
          <h3 class="font-semibold text-text-primary mb-2">AI-Enhanced Research</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            We utilise modern AI-enhanced research tools to analyse large datasets and identify market trends at scale.
          </p>
        </div>
        <!-- Pillar 2 -->
        <div class="py-4 sm:py-0 sm:px-6 sm:border-r sm:border-border border-t sm:border-t-0 border-border">
          <p class="text-xs font-bold uppercase tracking-[0.12em] text-accent mb-2">02</p>
          <h3 class="font-semibold text-text-primary mb-2">Human Review</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Every piece of content is personally reviewed and fact-checked to ensure it meets our standards for academic depth and accuracy.
          </p>
        </div>
        <!-- Pillar 3 -->
        <div class="py-4 sm:py-0 sm:pl-6 border-t sm:border-t-0 border-border">
          <p class="text-xs font-bold uppercase tracking-[0.12em] text-accent mb-2">03</p>
          <h3 class="font-semibold text-text-primary mb-2">Team Refinement</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Content is refined by our team to ensure a personal, human touch — because education should feel like a conversation, not a lecture.
          </p>
        </div>
      </div>
    </section>

    <Separator />

    <!-- Our Mission -->
    <section class="py-12 lg:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <div class="w-12 h-[2px] bg-accent mx-auto mb-6"></div>
        <p class="text-xs font-bold uppercase tracking-[0.12em] text-accent mb-4">Our Mission</p>
        <p class="font-serif text-3xl lg:text-4xl text-text-primary leading-snug mb-6">
          To make economics and business education accessible, engaging and genuinely useful.
        </p>
        <p class="text-text-secondary text-base leading-relaxed max-w-lg mx-auto mb-6">
          We're here to help the next generation of thinkers and leaders decode the global economy with confidence.
        </p>
        <p class="font-serif text-xl text-accent italic">
          Let's make sense of the markets together.
        </p>
      </div>
    </section>

    <Separator />

    <!-- CTA Section -->
    <section class="py-10 lg:py-14">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-center gap-6 sm:gap-12">
        <a href="/education" class="group flex items-center gap-2 text-text-primary hover:text-accent transition-colors">
          <span class="text-lg font-semibold">Explore our revision guides</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <div class="hidden sm:block w-px h-6 bg-border" aria-hidden="true"></div>
        <a href="/blog" class="group flex items-center gap-2 text-text-primary hover:text-accent transition-colors">
          <span class="text-lg font-semibold">Explore news</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>
  </Container>
</BaseLayout>
