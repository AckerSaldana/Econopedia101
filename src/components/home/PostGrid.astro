---
import PostCard from '../blog/PostCard.astro';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';

interface Props {
  posts: Array<{
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata | string;
      coverAlt: string;
      coverIsUrl?: boolean;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  }>;
  title: string;
}

const { posts, title } = Astro.props;
---

<section class="py-(--spacing-block)">
  <Container>
    <SectionHeading title={title} href="/blog" />

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      {posts.slice(0, 4).map((post) => (
        <div>
          <PostCard post={post} loading="eager" />
        </div>
      ))}
    </div>
  </Container>
</section>
