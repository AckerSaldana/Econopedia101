---
import Container from '../ui/Container.astro';

const tools = [
  {
    name: 'Compound Interest Calculator',
    description: 'See how your money grows over time with compound interest.',
    href: '/tools/compound-interest-calculator',
  },
  {
    name: 'ROI Calculator',
    description: 'Calculate return on investment for any asset or project.',
    href: '/tools/roi-calculator',
  },
  {
    name: 'Inflation Calculator',
    description: 'Understand how inflation affects your purchasing power.',
    href: '/tools/inflation-calculator',
  },
  {
    name: 'Profit & Loss Calculator',
    description: 'Track your trading profits and losses with precision.',
    href: '/tools/profit-loss-calculator',
  },
];
---

<section class="py-10 lg:py-14">
  <Container>
    <!-- Section heading -->
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="w-8 h-0.5 bg-accent mb-3" aria-hidden="true"></div>
        <h2 class="font-serif text-2xl text-text-primary">Interactive Tools</h2>
      </div>
      <a href="/tools" class="text-xs text-text-muted hover:text-accent transition-colors">
        View all <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border border border-border">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="group block p-6 bg-background hover:bg-surface-elevated transition-colors"
        >
          <h3 class="font-semibold text-text-primary text-sm mb-2 group-hover:text-accent transition-colors">
            {tool.name}
          </h3>
          <p class="text-xs text-text-muted leading-relaxed">
            {tool.description}
          </p>
          <span class="inline-block mt-3 text-xs font-medium text-accent">
            Try it <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </Container>
</section>
