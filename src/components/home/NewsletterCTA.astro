---
import Container from '../ui/Container.astro';
---

<section class="py-6 lg:py-8 border-y border-border bg-surface-elevated">
  <Container>
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <!-- Left: copy -->
      <div class="flex-1">
        <p class="text-[10px] font-bold uppercase tracking-[0.12em] text-accent mb-2">Newsletter</p>
        <h2 class="text-xl font-bold text-text-primary">
          Stay informed.
        </h2>
        <p class="mt-1 text-text-secondary text-sm leading-relaxed">
          Weekly economics and finance insights delivered to your inbox.
        </p>
      </div>

      <!-- Right: form -->
      <div class="flex-1 max-w-md">
        <form
          action="#"
          method="POST"
          class="flex"
        >
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="flex-1 px-4 py-2.5 border border-border border-r-0 bg-background text-text-primary placeholder:text-text-muted text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 bg-text-primary text-background px-5 py-2.5 text-sm font-medium hover:bg-text-secondary transition-colors border border-text-primary whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-2 text-xs text-text-muted">
          No spam, ever. Unsubscribe anytime.
        </p>
      </div>
    </div>
  </Container>
</section>
