---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Breadcrumbs from '../../components/common/Breadcrumbs.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { TrendingUp, BarChart3, PiggyBank, TrendingDown } from 'lucide-react';

const tools = await getCollection('tools');

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools & Calculators' },
];

const iconMap: Record<string, string> = {
  TrendingUp: '📈',
  BarChart3: '📊',
  PiggyBank: '🏦',
  TrendingDown: '📉',
};

// Get 3 recent posts for related reading
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Tools & Calculators | Econopedia 101"
  description="Free interactive finance calculators — compound interest, profit & loss, ROI, and inflation. Make smarter money decisions with data."
>
  <Container>
    <div class="py-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <header class="mb-12">
      <h1 class="font-serif text-4xl lg:text-5xl font-semibold text-text-primary leading-tight">
        Tools & Calculators
      </h1>
      <p class="mt-3 text-text-secondary text-lg max-w-2xl leading-relaxed">
        Free interactive calculators to help you understand key financial concepts, plan your investments, and make smarter decisions.
      </p>
    </header>

    <!-- Tool cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {tools.map((tool) => (
        <a
          href={`/tools/${tool.data.slug}`}
          class="group bg-surface border-b border-border hover:border-text-muted transition-colors duration-200 p-6"
        >
          <div class="text-2xl mb-3">{iconMap[tool.data.icon] || '🧮'}</div>
          <h2 class="font-serif text-xl font-semibold text-text-primary group-hover:text-accent transition-colors mb-2">
            {tool.data.name}
          </h2>
          <p class="text-sm text-text-secondary leading-relaxed">
            {tool.data.description}
          </p>
          <span class="inline-block mt-4 text-xs font-bold uppercase tracking-wider text-accent">
            Use calculator →
          </span>
        </a>
      ))}
    </div>

    <!-- Related reading -->
    {allPosts.length > 0 && (
      <div class="border-t border-border pt-10 pb-16">
        <h2 class="font-serif text-2xl font-semibold text-text-primary mb-6">
          Related Reading
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {allPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </div>
    )}
  </Container>
</BaseLayout>
