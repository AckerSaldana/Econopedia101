---
import Container from '../ui/Container.astro';
---

<section class="py-10 lg:py-14 border-y border-border">
  <Container>
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-serif text-2xl md:text-3xl text-text-primary">
        Stay informed.
      </h2>
      <p class="mt-3 text-text-secondary text-sm leading-relaxed">
        Weekly economics and finance insights delivered to your inbox.
      </p>

      <form
        action="#"
        method="POST"
        class="mt-6 flex flex-col sm:flex-row gap-3 justify-center"
      >
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
          class="flex-1 max-w-sm px-4 py-3 border border-border bg-transparent text-text-primary placeholder:text-text-muted text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent transition-colors"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 bg-text-primary text-background px-5 py-3 text-sm font-medium hover:bg-text-secondary transition-colors"
        >
          Subscribe
        </button>
      </form>

      <p class="mt-4 text-xs text-text-muted">
        No spam, ever. Unsubscribe anytime.
      </p>
    </div>
  </Container>
</section>
