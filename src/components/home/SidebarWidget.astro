---
interface Props {
  title?: string;
}

const { title = "Editor's Picks" } = Astro.props;
---

<aside class="pt-1">
  <!-- Section label -->
  <h3 class="text-xs uppercase tracking-widest font-semibold text-text-secondary pb-3 border-b border-border">
    {title}
  </h3>

  <!-- Slotted story items separated by thin rules -->
  <div class="divide-y divide-border">
    <slot>
      <div class="py-4">
        <p class="text-xs text-text-muted italic">No picks yet. Check back soon.</p>
      </div>
    </slot>
  </div>
</aside>
