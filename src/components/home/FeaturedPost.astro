---
import { Image } from 'astro:assets';
import CategoryBadge from '../blog/CategoryBadge.astro';
import { formatDate } from '../../lib/utils';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata;
      coverAlt: string;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  };
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const { title, description, cover, coverAlt, categories, publishedAt, author } = post.data;

const authorName = author.id.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<a href={`/blog/${post.slug}`} class="group block">
  <!-- Featured image — constrained aspect ratio, no border -->
  <div class="aspect-[16/9] overflow-hidden mb-5">
    <Image
      src={cover}
      alt={coverAlt}
      widths={[400, 600, 800]}
      sizes="(max-width: 1024px) 100vw, 66vw"
      class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
    />
  </div>

  <!-- Category label -->
  {categories[0] && (
    <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">
      {categories[0].replace(/-/g, ' ')}
    </p>
  )}

  <!-- Headline -->
  <h2 class="font-serif text-2xl lg:text-3xl font-semibold leading-tight text-text-primary group-hover:text-accent transition-colors">
    {title}
  </h2>

  <!-- Excerpt -->
  <p class="mt-3 text-text-secondary text-base leading-relaxed line-clamp-3">
    {description}
  </p>

  <!-- Byline -->
  <div class="mt-3 flex items-center gap-2 text-xs text-text-muted">
    <span class="font-medium text-text-secondary">{authorName}</span>
    <span aria-hidden="true">&middot;</span>
    <time datetime={publishedAt.toISOString()}>
      {formatDate(publishedAt)}
    </time>
    {readingTime && (
      <>
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime}</span>
      </>
    )}
  </div>
</a>
