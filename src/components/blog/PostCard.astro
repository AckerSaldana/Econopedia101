---
import { Image } from 'astro:assets';
import CategoryBadge from './CategoryBadge.astro';
import { formatDate } from '../../lib/utils';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata;
      coverAlt: string;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  };
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const { title, description, cover, coverAlt, categories, publishedAt, author } = post.data;
---

<a
  href={`/blog/${post.slug}`}
  class="group block border-b border-border last:border-b-0"
>
  <!-- Image: no rounded corners, no hover scale, subtle opacity shift -->
  <div class="aspect-[3/2] overflow-hidden">
    <Image
      src={cover}
      alt={coverAlt}
      widths={[400, 600, 800]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
      class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
    />
  </div>

  <!-- Content: typography-driven hierarchy, no card chrome -->
  <div class="pt-4 pb-6">
    {categories[0] && <CategoryBadge category={categories[0]} />}

    <h3 class="font-serif text-base lg:text-lg font-semibold leading-snug text-text-primary mt-2 group-hover:text-accent transition-colors duration-200">
      {title}
    </h3>

    <p class="text-text-secondary text-sm mt-2 line-clamp-2 leading-relaxed">
      {description}
    </p>

    <div class="flex items-center gap-1.5 text-xs text-text-muted mt-3">
      <span>{author.id.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
      <span aria-hidden="true">&middot;</span>
      <time datetime={publishedAt.toISOString()}>
        {formatDate(publishedAt)}
      </time>
      {readingTime && (
        <>
          <span aria-hidden="true">&middot;</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
  </div>
</a>
