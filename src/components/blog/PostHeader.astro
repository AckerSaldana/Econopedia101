---
import { Image } from 'astro:assets';
import CategoryBadge from './CategoryBadge.astro';
import { formatDate } from '../../lib/utils';

interface Props {
  title: string;
  description: string;
  categories: string[];
  publishedAt: Date;
  updatedAt?: Date;
  author: {
    name: string;
    avatar: ImageMetadata;
    role: string;
  };
  readingTime: string;
  cover: ImageMetadata;
  coverAlt: string;
}

const {
  title,
  description,
  categories,
  publishedAt,
  updatedAt,
  author,
  readingTime,
  cover,
  coverAlt,
} = Astro.props;
---

<header class="text-center">
  <!-- Categories -->
  <div class="flex flex-wrap items-center justify-center gap-2">
    {categories.map((cat) => (
      <CategoryBadge category={cat} size="md" />
    ))}
  </div>

  <!-- Title -->
  <h1 class="mt-3 text-4xl lg:text-5xl font-semibold text-text-primary leading-tight">
    {title}
  </h1>

  <!-- Description -->
  <p class="mt-3 text-lg text-text-secondary leading-relaxed max-w-prose mx-auto">
    {description}
  </p>

  <!-- Cover image -->
  <div class="mt-6 overflow-hidden max-w-3xl mx-auto">
    <Image
      src={cover}
      alt={coverAlt}
      widths={[600, 900, 1200]}
      sizes="(max-width: 768px) 100vw, 672px"
      class="w-full aspect-[2/1] object-cover"
    />
  </div>

  <!-- Meta line beneath image -->
  <div class="mt-4 flex flex-wrap items-center justify-center gap-x-2 text-sm text-text-secondary">
    <span class="font-medium text-text-primary">{author.name}</span>
    <span aria-hidden="true">&middot;</span>
    <time datetime={publishedAt.toISOString()}>
      {formatDate(publishedAt)}
    </time>
    {updatedAt && (
      <>
        <span aria-hidden="true">&middot;</span>
        <span>
          Updated <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt)}</time>
        </span>
      </>
    )}
    <span aria-hidden="true">&middot;</span>
    <span>{readingTime}</span>
  </div>
</header>
