---
interface Props {
  title: string;
  description: string;
  color: string;
  postCount: number;
}

const { title, description, color, postCount } = Astro.props;
---

<header class="relative mb-10 pl-6 border-l-4" style={`border-color: ${color}`}>
  <div class="flex flex-wrap items-center gap-3 mb-3">
    <h1 class="font-serif text-4xl lg:text-5xl font-semibold text-text-primary">
      {title}
    </h1>
    <span
      class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold text-white"
      style={`background-color: ${color}`}
    >
      {postCount} {postCount === 1 ? 'article' : 'articles'}
    </span>
  </div>
  <p class="text-text-secondary text-lg max-w-2xl leading-relaxed">
    {description}
  </p>
</header>
