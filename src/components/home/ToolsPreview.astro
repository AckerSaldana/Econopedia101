---
import Container from '../ui/Container.astro';

const tools = [
  {
    name: 'Compound Interest Calculator',
    description: 'See how your money grows over time with compound interest.',
    href: '/tools/compound-interest-calculator',
  },
  {
    name: 'ROI Calculator',
    description: 'Calculate return on investment for any asset or project.',
    href: '/tools/roi-calculator',
  },
  {
    name: 'Inflation Calculator',
    description: 'Understand how inflation affects your purchasing power.',
    href: '/tools/inflation-calculator',
  },
  {
    name: 'Profit & Loss Calculator',
    description: 'Track your trading profits and losses with precision.',
    href: '/tools/profit-loss-calculator',
  },
];
---

<section class="py-5 lg:py-6">
  <Container>
    <!-- Economist-style section heading -->
    <div class="border-t-2 border-text-primary pt-3 mb-4 flex items-baseline justify-between">
      <h2 class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">Interactive Tools</h2>
      <a href="/tools" class="text-[10px] text-text-muted hover:text-accent transition-colors">
        View all &rarr;
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border border border-border">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="group block p-4 bg-background hover:bg-surface-elevated transition-colors"
        >
          <h3 class="font-bold text-text-primary text-xs mb-1 group-hover:text-accent transition-colors">
            {tool.name}
          </h3>
          <p class="text-xs text-text-muted leading-relaxed">
            {tool.description}
          </p>
          <span class="inline-block mt-2 text-xs font-medium text-accent">
            Try it <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </Container>
</section>
