---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import Separator from '../components/ui/Separator.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { SITE } from '../lib/constants';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Privacy Policy' },
];

const lastUpdated = '14 March 2026';

const sections = [
  { id: 'transparency', label: 'Transparency & Data Protection' },
  { id: 'cookies', label: 'Cookie Usage' },
  { id: 'affiliate', label: 'Affiliate Marketing Disclosure' },
  { id: 'ai-transparency', label: 'AI Transparency & Research Disclosure' },
  { id: 'research-data', label: 'Research Data & Professional Insights' },
  { id: 'your-rights', label: 'Your Rights' },
  { id: 'contact', label: 'Contact Us' },
];
---

<BaseLayout title="Privacy Policy | Econopedia 101" description="Read the Econopedia 101 privacy policy. Learn how we collect, use, and protect your personal data under UK GDPR.">
  <Container>
    <div class="py-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <article>
      <!-- Hero Section -->
      <section class="py-5 lg:py-6">
        <div class="border-t-2 border-text-primary pt-3 mb-4">
          <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">Legal</p>
        </div>
        <h1 class="text-4xl lg:text-5xl font-semibold text-text-primary mb-3">
          Privacy Policy
        </h1>
        <p class="text-xl text-text-secondary leading-relaxed mb-2">
          Your Privacy Matters to Us
        </p>
        <p class="text-sm text-text-muted">
          Last updated: {lastUpdated}
        </p>
      </section>

      <!-- Intro + Table of Contents -->
      <section class="py-5 lg:py-6">
        <div class="grid lg:grid-cols-[2fr_1px_1fr] gap-y-4 lg:gap-y-0">
          <div class="lg:pr-5 text-text-secondary text-base leading-relaxed">
            <p>
              Welcome to {SITE.name}. Your privacy is fundamentally important to us. This policy outlines
              how we collect, use and protect your information as you explore our learning platform,
              news hub and revision resources.
            </p>
          </div>

          <!-- Vertical rule -->
          <div class="hidden lg:block bg-border" aria-hidden="true"></div>

          <div class="border-t lg:border-t-0 border-border pt-4 lg:pt-0 lg:pl-5">
            <nav aria-label="Table of contents">
              <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary mb-3">In this policy</p>
              <ol class="space-y-1.5">
                {sections.map((section, i) => (
                  <li>
                    <a href={`#${section.id}`} class="text-sm text-accent hover:underline">
                      {i + 1}. {section.label}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        </div>
      </section>

      <Separator />

      <!-- Section 1: Transparency & Data Protection -->
      <section id="transparency" class="py-5 lg:py-6 scroll-mt-32">
        <SectionHeading title="1. Transparency & Data Protection (UK GDPR)" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            As a UK-based platform, we comply with the UK General Data Protection Regulation (UK GDPR).
            We only collect personal information, such as your name or email address, when you voluntarily
            provide it — for example, by subscribing to our newsletter or using our contact form.
          </p>
          <p>
            We strictly do not sell or rent your personal data to third parties.
          </p>
        </div>
      </section>

      <!-- Section 2: Cookie Usage -->
      <section id="cookies" class="py-5 lg:py-6 scroll-mt-32">
        <SectionHeading title="2. Cookie Usage" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            {SITE.name} uses cookies to enhance your experience. Cookies are small text files stored
            on your device that help us analyse web traffic, remember your preferences and see which
            parts of our site are most useful to students and professionals.
          </p>
          <ul class="list-disc pl-6 space-y-2">
            <li>
              <strong class="text-text-primary">Analytics:</strong> We may use service providers
              to monitor and analyse the use of our site.
            </li>
            <li>
              <strong class="text-text-primary">Management:</strong> You can choose to accept or
              decline cookies through your browser settings or the consent banner on our homepage.
            </li>
          </ul>
        </div>
      </section>

      <!-- Section 3: Affiliate Marketing Disclosure -->
      <section id="affiliate" class="py-5 lg:py-6 scroll-mt-32">
        <SectionHeading title="3. Affiliate Marketing Disclosure" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            {SITE.name} is a reader-supported platform. We participate in affiliate marketing programs,
            which means we may earn a small commission on qualifying purchases made through our links
            — such as for recommended textbooks or calculators.
          </p>
          <p>
            This happens at no additional cost to you and helps us maintain our educational resources.
            We only recommend products that we believe provide genuine value to your wider economic,
            financial and business studies.
          </p>
        </div>
      </section>

      <!-- Section 4: AI Transparency & Research Disclosure -->
      <section id="ai-transparency" class="py-5 lg:py-6 scroll-mt-32">
        <SectionHeading title="4. AI Transparency & Research Disclosure" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            In line with EU AI Act (Regulation 2024/1689), we disclose that {SITE.name} utilises
            advanced AI tools to assist in data research and market trend synthesis. However, we
            operate under a strict Human-in-the-Loop editorial model.
          </p>
          <p>
            Every article is manually reviewed, fact-checked and refined by our team to ensure
            academic accuracy and a personal, human touch.
          </p>
        </div>
      </section>

      <!-- Section 5: Research Data & Professional Insights -->
      <section id="research-data" class="py-5 lg:py-6 scroll-mt-32">
        <SectionHeading title="5. Research Data & Professional Insights" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            While we utilise high-level data from professional financial tools such as Bloomberg
            for research purposes, {SITE.name} is an independent educational platform.
          </p>
          <p>
            Please note that our content is strictly for educational and informational purposes
            and does not constitute financial advice.
          </p>
        </div>
      </section>

      <!-- Section 6: Your Rights -->
      <section id="your-rights" class="py-5 lg:py-6 scroll-mt-32">
        <SectionHeading title="6. Your Rights" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            Under UK data protection law, you have the right to access, correct or delete your
            personal data. You also have the right to withdraw your consent to our use of cookies
            at any time.
          </p>
        </div>
      </section>

      <!-- Section 7: Contact Us -->
      <section id="contact" class="pt-5 lg:pt-6 pb-12 lg:pb-16 scroll-mt-32">
        <SectionHeading title="7. Contact Us" />
        <div class="max-w-3xl text-text-secondary text-base leading-relaxed space-y-4">
          <p>
            If you have any questions regarding this Privacy Policy or how we handle your data,
            please do not hesitate to contact us at{' '}
            <a href="mailto:info@econopedia101.com" class="text-accent hover:underline">info@econopedia101.com</a>.
          </p>
          <p>
            We value your privacy and aim to respond to all inquiries promptly.{' '}
            <a href="/about" class="text-accent hover:underline">See more about us</a>.
          </p>
        </div>
      </section>
    </article>
  </Container>
</BaseLayout>
