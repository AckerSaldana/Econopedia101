---
import PostCard from '../blog/PostCard.astro';
import Container from '../ui/Container.astro';

interface Props {
  posts: Array<{
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata;
      coverAlt: string;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  }>;
  title: string;
}

const { posts, title } = Astro.props;
---

<section class="py-10 lg:py-14">
  <Container>
    <!-- Section heading with short accent-colored top rule -->
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="w-8 h-0.5 bg-accent mb-3" aria-hidden="true"></div>
        <h2 class="font-serif text-2xl text-text-primary">{title}</h2>
      </div>
      <a href="/blog" class="text-xs text-text-muted hover:text-accent transition-colors">
        View all <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {posts.slice(0, 4).map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </Container>
</section>
